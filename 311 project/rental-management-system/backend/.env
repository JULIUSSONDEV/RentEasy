# ============================================================
# RENTAL MANAGEMENT SYSTEM - ENVIRONMENT VARIABLES
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=rental_management

# JWT
JWT_SECRET=renteasy_super_secret_jwt_key_2025_production_ready
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://127.0.0.1:5500

# File Upload
MAX_FILE_SIZE_MB=20
UPLOAD_PATH=./uploads

# Email (Nodemailer - optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="RentEasy <your_email@gmail.com>"

# ============================================================
# PAYHERO - M-Pesa STK Push via PayHero
# ============================================================
# Set PAYHERO_ENABLED=true to use real PayHero STK Push.
# Set PAYHERO_ENABLED=false for demo/simulation mode (auto-confirms after 5s).
PAYHERO_ENABLED=true

# Get credentials from https://app.payhero.co.ke (API Settings)
PAYHERO_API_USERNAME=LUpOhcQGHre3HyvDM2FT
PAYHERO_API_PASSWORD=eNPoXzssjqBbespmk3TE2kGL7esirweVG7JFU574
PAYHERO_CHANNEL_ID=5105

# Pre-computed Basic Auth token (base64 of username:password)
PAYHERO_AUTH_TOKEN=Basic TFVwT2hjUUdIcmUzSHl2RE0yRlQ6ZU5Qb1h6c3NqcUJiZXNwbWszVEUya0dMN2VzaXJ3ZVZHN0pGVTU3NA==

# Public URL PayHero will POST the payment result to (must be HTTPS and publicly reachable)
# For local testing use ngrok: ngrok http 5000  and set the https URL below
PAYHERO_CALLBACK_URL=https://yourdomain.com/api/payments/payhero/callback
